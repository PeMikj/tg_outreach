TG_OUTREACH_POSTGRES_DB=tg_outreach
TG_OUTREACH_POSTGRES_USER=postgres
TG_OUTREACH_POSTGRES_PASSWORD=postgres
TG_OUTREACH_BUILD_VERSION=dev
TG_OUTREACH_GIT_SHA=unknown
TG_OUTREACH_USER_HEADLINE=Senior Python/ML engineer focused on backend systems and MLOps
TG_OUTREACH_USER_SKILLS=python,fastapi,backend,mlops,llm,infra,docker,postgresql,observability
TG_OUTREACH_MIN_SCORE=0.20
TG_OUTREACH_MAX_DAILY_OUTREACH=3
TG_OUTREACH_ASTRIXA_TIMEOUT_SECONDS=8
TG_OUTREACH_CONTEXT_BUDGET_TOKENS=3000
TG_OUTREACH_APPROVAL_TTL_SECONDS=86400
TG_OUTREACH_FOLLOW_UP_DELAY_SECONDS=259200
TG_OUTREACH_WORKER_POLL_SECONDS=15
TG_OUTREACH_TELEGRAM_REPLY_POLL_INTERVAL_SECONDS=300
